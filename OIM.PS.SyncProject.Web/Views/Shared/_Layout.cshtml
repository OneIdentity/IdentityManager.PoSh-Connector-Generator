<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - OIM.PS.SyncProject.Web</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/OIM.PS.SyncProject.Web.styles.css" asp-append-version="true" />
</head>
<body>
    @if (ViewData["HideNavbar"] == null)
    {
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark shadow-sm mb-1" style="background-color: var(--oi-primary);">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold d-flex align-items-center gap-2" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="/images/Logo.png" alt="Logo" style="height: 28px;" />
                    PS Sync Project Generator
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Generator" asp-action="Index">Generator</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#" data-bs-toggle="modal" data-bs-target="#helpModal">Help</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    }
    <div class="container-fluid px-3">
        <main role="main" class="pb-0">
            @RenderBody()
        </main>
    </div>

    @if (ViewData["HideNavbar"] == null)
    {
    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - OIM.PS.SyncProject.Web - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    }
    <!-- ============ MODAL: Help ============ -->
    <div class="modal fade" id="helpModal" tabindex="-1" aria-labelledby="helpModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="helpModalLabel" style="color: var(--oi-primary);">Help &amp; Information</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <ul class="list-unstyled mb-0">
                        <li class="mb-3">
                            <a href="/docs/Help.pdf" target="_blank" class="d-flex align-items-center gap-2 text-decoration-none">
                                <span>&#128196;</span> <span>Documentation (PDF)</span>
                            </a>
                        </li>
                        <li class="mb-3">
                            <a href="https://github.com/OneIdentity/IdentityManager.PoSh-Connector-Generator" target="_blank" class="d-flex align-items-center gap-2 text-decoration-none">
                                <span>&#128279;</span> <span>GitHub Repository</span>
                            </a>
                        </li>
                        <li class="pt-2 border-top text-muted small">
                            For comments or suggestions please contact<br />
                            <strong>Paul Sherman</strong> &mdash; <a href="mailto:paul.sherman@oneidentity.demo">paul.sherman@oneidentity.demo</a>
                        </li>
                    </ul>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-oi-outline" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>

        <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
